# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://fcc_user:changeme@localhost:5432/fcc_db
DATABASE_URL_SYNC=postgresql+psycopg2://fcc_user:changeme@localhost:5432/fcc_db

# ── JWT ───────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-64-char-random-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=15
# 32-byte base64 key for AES-256-GCM investment secure details.
# Generate with: openssl rand -base64 32
INVESTMENT_SECURE_DETAILS_KEY=change-me-with-openssl-rand-base64-32

# ── Email (Zoho SMTP) ─────────────────────────────────────────


EMAIL_PROVIDER=smtp
SMTP_HOST=smtppro.zoho.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-zoho-app-password
SMTP_FROM_NAME=Financial Command Center

# ── App ───────────────────────────────────────────────────────
FRONTEND_URL=https://finfreak.shivomsangha.com
ADMIN_EMAIL=admin@yourdomain.com
ALLOWED_ORIGINS=["http://localhost:3100","http://127.0.0.1:3100","https://finfreak.shivomsangha.com"]
APP_DEBUG=true

# ── Frontend ──────────────────────────────────────────────────
# Create frontend/.env.local with:
# BACKEND_URL=http://localhost:8100
#
# BACKEND_URL is server-side only and powers the Next.js /api rewrite.
# Browser code uses relative /api/... paths and never needs the backend origin.

# ── Exchange Rate Scheduler ───────────────────────────────────
EXCHANGE_RATE_FETCH_HOUR_IST=9
EXCHANGE_RATE_FETCH_MINUTE_IST=0
